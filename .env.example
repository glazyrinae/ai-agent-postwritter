UID=1000
GID=1000

API_BEARER_TOKEN=change-me
API_HOST=0.0.0.0
API_PORT=8080
API_PUBLISHED_PORT=8080
DATABASE_URL=postgresql://article_service:article_service@db:5432/article_service
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_PUBLISHED_PORT=5432
POSTGRES_DB=article_service
POSTGRES_USER=article_service
POSTGRES_PASSWORD=article_service
PGDATA=/var/lib/postgresql/data/pgdata

HF_TOKEN=hf_your_token_here
MODEL_ID=MTSAIR/Cotype-Nano-4bit
MODEL_DIR=/models/cotype-nano
MODEL_HOST_DIR=./deploy/models
VLLM_SOURCE_REF=v0.8.5
LLM_BACKEND=ollama
LLM_BASE_URL=http://ollama-server:11434
LLM_REQUEST_TIMEOUT_SECONDS=1800
LLM_DEFAULT_MODEL=hodza/cotype-nano-1.5-unofficial
OLLAMA_HOST_DIR=./deploy/models/ollama
OLLAMA_MODEL_NAME=hodza/cotype-nano-1.5-unofficial
OLLAMA_PUBLISHED_PORT=11435
OLLAMA_BASE_MODEL=hodza/cotype-nano-1.5-unofficial:latest
LLAMA_CPP_REF=master

VLLM_PORT=8000
VLLM_PUBLISHED_PORT=8000
VLLM_DTYPE=bfloat16
VLLM_CPU_KVCACHE_SPACE=4
VLLM_CPU_NUM_OF_RESERVED_CPU=1
VLLM_USE_AOT_COMPILE=0
VLLM_DISABLE_COMPILE_CACHE=1
VLLM_MAX_LORAS=5
VLLM_MAX_LORA_RANK=64
VLLM_MAX_MODEL_LEN=2048
VLLM_MAX_NUM_SEQS=1
HF_HUB_OFFLINE=1
VLLM_ALLOW_RUNTIME_LORA_UPDATING=true
SHM_SIZE=4g

# Compatibility envs for the existing Python settings layer.
VLLM_URL=http://vllm-server:8000
DEFAULT_TEMPERATURE=0.3
MAX_TOKENS=2048
DEFAULT_MODEL=cotype-nano
LORA_HOST_DIR=./deploy/lora_adapters

ARTICLE_DEFAULT_SECTIONS=5
ARTICLE_DEFAULT_TARGET_AUDIENCE=IT engineers
ARTICLE_DEFAULT_STYLE=практический технический блог
ARTICLE_DEFAULT_INCLUDE_CODE_EXAMPLES=true
ARTICLE_OUTLINE_MAX_TOKENS=800
ARTICLE_CHAPTER_MAX_TOKENS=1700
ARTICLE_SUMMARY_MAX_TOKENS=400
ARTICLE_PROOFREAD_MAX_TOKENS=2600
ARTICLE_MIN_SECTION_CHARS=200
ARTICLE_CONTEXT_SECTIONS_LIMIT=3
